{
  "name": "cabada-saas",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "dev:web": "vite --config vite.config.js --port 5173",
    "build:web": "vite build --config vite.config.js",
